{
  "name": "self-tune",
  "version": "1.0.1",
  "description": "A native desktop app to track your weekly progress and build consistency",
  "author": "Self Tune Contributors",
  "homepage": "https://github.com/ahadulhaquenaim/self-tune",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahadulhaquenaim/self-tune.git"
  },
  "private": false,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder --linux",
    "install-desktop": "node scripts/install-desktop.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.selftune.app",
    "productName": "Self Tune",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
